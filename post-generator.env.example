# Copy these into your root `.env` (or Infisical) next to docker-compose.yml.
# Shared with the rest of the stack:
#   RABBITMQ_USER, RABBITMQ_PASSWORD  (already required for RabbitMQ)
# Optional shared:
#   ENVIRONMENT, DEBUG

# =============================================================================
# ai_post_generator — service `post_generator_service` (RabbitMQ consumer)
# =============================================================================
# Optional: override images (defaults in docker-compose.dev.yml:
#   ivanskrb21/bidauto_post_generator_service:latest
#   ivanskrb21/bidauto_post_generator_bot:latest)
# POST_GENERATOR_SERVICE_IMAGE=
# POST_GENERATOR_BOT_IMAGE=

POST_GENERATOR_DB_USER=
POST_GENERATOR_DB_PASS=
POST_GENERATOR_DB_NAME=

POST_GENERATOR_OPENAI_API_KEY=

# gRPC host:port (no scheme). Должно указывать на реальный ChatBot gRPC, если им пользуется код; иначе задайте валидный хост из стека (см. Infisical dev).
POST_GENERATOR_RPC_CHAT_BOT_URL=

# =============================================================================
# ai_post_bot — `post_generator_bot` (polling) + `post_generator_bot_rabbit`
# =============================================================================
POST_GENERATOR_BOT_DB_USER=
POST_GENERATOR_BOT_DB_PASS=
POST_GENERATOR_BOT_DB_NAME=

POST_GENERATOR_TELEGRAM_BOT_TOKEN=
POST_GENERATOR_SECRET_BOT_KEY=

# Форум-супергруппа + один JSON с topic id (message_thread_id) на язык.
# Порядок в массиве: lt, pl, lv, et, uk, en — как в генераторе постов.
# Пример массива:
# POST_GENERATOR_TELEGRAM_TOPIC_IDS_JSON=[2,10,11,12,13,14]
# Или объект (те же ключи):
# POST_GENERATOR_TELEGRAM_TOPIC_IDS_JSON={"lt":2,"pl":10,"lv":11,"et":12,"uk":13,"en":14}
POST_GENERATOR_TELEGRAM_FORUM_CHAT_ID=
POST_GENERATOR_TELEGRAM_TOPIC_IDS_JSON=
